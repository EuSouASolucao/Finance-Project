PORT=3333
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=financeapp
DB_CONNECTION_LIMIT=10

JWT_SECRET=troque_esta_chave_por_uma_chave_segura
JWT_EXPIRES_IN=7d

VITE_API_URL=https://luisaugusto.eng.br/financeiro/api/index.php

# Caminho público do SPA (barra final). Obrigatório em produção se o site abre como /financeiro#/...
# sem barra final — caso contrário ./assets resolve para /assets e o bundle nem carrega (tela branca).
# Na raiz do domínio use: VITE_BASE_URL=/
VITE_BASE_URL=/financeiro/
